    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Runs once per outbox row. `$json` is the enriched-booking HTTP response\n// (an array from PostgREST). The outbox row itself is available upstream via\n// the \"Split outbox rows\" node.\nconst outbox = $('Split outbox rows').item.json;\nconst payload = outbox.payload || {};\n// The enrich HTTP node may surface PostgREST's array as a bare array, a\n// {data:[...]} wrapper, OR (n8n's default) a single split item whose $json IS\n// the booking object. Handle all three so member_id/request_text populate.\nlet booking = {};\nif (Array.isArray($json)) booking = $json[0] || {};\nelse if (Array.isArray($json.data)) booking = $json.data[0] || {};\nelse if ($json && ($json.id || $json.member_id)) booking = $json;\n\n// Resulting status: payload.status for 'booking.created', payload.to for\n// 'booking.status_changed'. Fall back to the freshly fetched row.\nconst resultingStatus = payload.status || payload.to || booking.status || null;\n\n// member_id: present on status_changed payloads; otherwise from the fetched row.\nconst memberId = payload.member_id || booking.member_id || null;\nconst kind = payload.kind || booking.kind || null;\nconst requestText = booking.request_text || null;\n\n// window is a Postgres tstzrange rendered by PostgREST as e.g.\n// [\"2026-07-10T14:00:00+00:00\",\"2026-07-10T16:00:00+00:00\") — take the lower bound.\nfunction lowerBound(win) {\n  if (!win) return null;\n  const m = String(win).match(/[\\[(]\\s*\"?([^\",\\])]+)\"?/);\n  return m ? m[1] : null;\n}\nconst windowStart = lowerBound(booking.window);\n\n// Console enrichment (R6): human-readable fields for the Airtable projection,\n// pulled from the embedded resources the enrich query now selects. Optional-\n// chained so a booking with no property/tech/member still projects — delivery\n// must never fail on a missing embed.\nconst memberName = booking.members?.full_name ?? null;\nconst address = booking.properties?.address ?? null;\nconst techName = booking.techs?.display_name ?? null;\nconst pays = Array.isArray(booking.payments) ? booking.payments : [];\nlet depositStatus;\nif (pays.some((p) => p.status === 'paid')) depositStatus = 'paid';\nelse if (pays.some((p) => p.status === 'pending')) depositStatus = 'pending';\nelse if (booking.deposit_required) depositStatus = 'unpaid';\nelse depositStatus = 'n/a';\n\nconst showApprove = resultingStatus === 'scheduled';\nconst bid = payload.booking_id;\n\n// --- Airtable upsert record (idempotent on booking_id) ---\nconst airtableFields = {\n  booking_id: bid,\n  status: resultingStatus,\n  kind: kind,\n  member_id: memberId,\n  member_name: memberName,\n  address: address,\n  tech_name: techName,\n  deposit_status: depositStatus,\n  request_text: requestText,\n  last_synced: new Date().toISOString()\n};\nif (windowStart) airtableFields.window_start = windowStart;\n\n// --- Telegram message text ---\nconst lines = [];\nif (outbox.topic === 'booking.created') {\n  lines.push('🟦 New booking');\n} else {\n  lines.push('🔄 Booking status: ' + (payload.from || '?') + ' → ' + (payload.to || '?'));\n}\nlines.push('kind: ' + (kind || 'n/a'));\nlines.push('status: ' + (resultingStatus || 'n/a'));\nif (requestText) lines.push('“' + String(requestText).slice(0, 240) + '”');\nlines.push('id: ' + bid);\nconst telegramText = lines.join('\\n');\n\n// --- Telegram send body (chat_id + optional inline Approve keyboard) ---\nconst telegramBody = {\n  chat_id: Number($env.OWNER_CHAT_ID),\n  text: telegramText,\n  disable_web_page_preview: true\n};\nif (showApprove) {\n  telegramBody.reply_markup = {\n    inline_keyboard: [[\n      { text: '✅ Approve', callback_data: 'approve:' + bid },\n      { text: '↩︎ Needs info', callback_data: 'needsinfo:' + bid }\n    ]]\n  };\n}\n\nreturn {\n  json: {\n    outbox_id: outbox.id,\n    dedupe_key: outbox.dedupe_key,\n    topic: outbox.topic,\n    attempts: outbox.attempts || 0,\n    booking_id: bid,\n    resulting_status: resultingStatus,\n    show_approve: showApprove,\n    airtable_records: [{ fields: airtableFields }],\n    telegram_body: telegramBody\n  }\n};"
      },
