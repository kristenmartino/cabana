    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// One ACT step (Airtable or Telegram) failed. Compute the next attempt count\n// and a compact error string; decide whether this row should be dead-lettered.\n// `$json` here still carries the Build-actions fields plus n8n's error object.\nconst src = $('Build actions').item.json;\nconst outboxId = src.outbox_id;\nconst attempts = (src.attempts || 0) + 1;\nconst err = $json.error || {};\nconst message =\n  (err.message ? String(err.message) : '') ||\n  (err.description ? String(err.description) : '') ||\n  'ACT step failed';\nreturn {\n  json: {\n    outbox_id: outboxId,\n    attempts: attempts,\n    last_error: message.slice(0, 500),\n    dead_letter: attempts >= 5,\n    payload_topic: src.topic,\n    booking_id: src.booking_id\n  }\n};"
      },
