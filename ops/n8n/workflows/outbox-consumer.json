            }
          ]
        },
        "options": {}
      },
      "id": "11111111-1111-4111-8111-111111111105",
      "name": "Enrich booking row",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        100,
        40
      ],
      "credentials": {
        "httpCustomAuth": {
