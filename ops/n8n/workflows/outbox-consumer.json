    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize the PostgREST GET response into exactly one n8n item per outbox\n// row, regardless of how the HTTP Request node surfaced the JSON array\n// (auto-split into items, a single item wrapping the array, or a `data` key).\n// PostgREST returns a bare JSON array of outbox rows.\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  let rows;\n  if (Array.isArray(j)) {\n    rows = j;\n  } else if (Array.isArray(j.data)) {\n    rows = j.data;\n  } else if (j && j.id !== undefined && j.dedupe_key !== undefined) {\n    rows = [j];\n  } else {\n    rows = [];\n  }\n  for (const r of rows) out.push({ json: r });\n}\nreturn out;"
      },
      "id": "11111111-1111-4111-8111-111111111104",
      "name": "Split outbox rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -140,
        40
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://uuviebpmiwzjyabucheo.supabase.co/rest/v1/bookings",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "id",
              "value": "=eq.{{ $json.payload.booking_id }}"
            },
            {
              "name": "select",
              "value": "id,member_id,property_id,tech_id,kind,status,request_text,window,deposit_required,members(full_name),properties(address),techs(display_name),payments(status)"
            },
            {
              "name": "limit",
              "value": "1"
