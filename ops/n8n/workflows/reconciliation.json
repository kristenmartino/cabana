    {
      "id": "b2c3d4e5-6f7a-4b2c-9d0e-1f2a3b4c5d6e",
      "icon": "fa:globe",
      "name": "Count Supabase bookings",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -360,
        -120
      ],
      "parameters": {
        "method": "GET",
        "url": "https://uuviebpmiwzjyabucheo.supabase.co/rest/v1/bookings?select=id",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Prefer",
              "value": "count=exact"
            },
            {
              "name": "Range-Unit",
              "value": "items"
            },
            {
              "name": "Range",
              "value": "0-0"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": true
            }
          }
        }
      },
      "credentials": {
        "httpCustomAuth": {
          "id": "REPLACE_WITH_SUPABASE_CRED_ID",
