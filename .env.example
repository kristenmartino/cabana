# Cabana environment — copy to .env.local (Next.js) and set function secrets
# via `supabase secrets set` for edge functions. Full table + key-handling
# rules: docs/02-architecture.md §8. NOTHING secret ever gets a NEXT_PUBLIC_ prefix.

# --- Supabase (from `supabase start` output locally, or project settings) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=            # safe for the browser BY DESIGN (RLS is the guard)
SUPABASE_SERVICE_ROLE_KEY=                # server only; bypasses RLS; never log it

# --- Anthropic (triage, R2) --------------------------------------------------
ANTHROPIC_API_KEY=                        # server actions only

# --- Stripe (test mode for the demo, R4) ------------------------------------
# Local edge runtime reads these from supabase/functions/.env (gitignored).
# tests/webhooks signs fixtures itself: dummy STRIPE_SECRET_KEY +
# STRIPE_WEBHOOK_SECRET=whsec_cabana_local_test there is enough — no account.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...           # from `stripe listen` locally; dashboard secret in cloud
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Telegram (R7) -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=                       # from @BotFather
TELEGRAM_WEBHOOK_SECRET=                  # random string; registered via setWebhook

# --- Airtable (R6) -----------------------------------------------------------
AIRTABLE_TOKEN=                           # scoped PAT: this base only
AIRTABLE_BASE_ID=
WRITEBACK_SHARED_SECRET=                  # shared with the Airtable automation

# --- Email (member notifications via n8n, R5+R6) ----
RESEND_API_KEY=re_...    # transactional email — auth magic links + n8n ops alerts (R6, Slice 2c)

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
